generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["express_example"]
}

model Tenant {
  id   String @id
  name String

  @@schema("express_example")
}

model Post {
  id        String  @id @default(uuid())
  tenantId  String
  title     String
  published Boolean @default(false)

  @@index([tenantId])
  @@schema("express_example")
}
