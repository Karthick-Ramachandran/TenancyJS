{
  "name": "@tenancyjs/example-knex-postgres",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "migrate": "knex --knexfile knexfile.mjs migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.mjs migrate:rollback",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@tenancyjs/adapter-knex": "workspace:*",
    "@tenancyjs/core": "workspace:*",
    "knex": "3.3.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
