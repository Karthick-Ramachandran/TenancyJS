{
  "name": "@tenancyjs/adapter-typeorm",
  "version": "0.0.0",
  "description": "Fail-closed TypeORM 1 tenant isolation for PostgreSQL.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@tenancyjs/adapter-shared": "workspace:*",
    "@tenancyjs/core": "workspace:*"
  },
  "peerDependencies": {
    "typeorm": ">=1.0.0 <2"
  },
  "devDependencies": {
    "typeorm": "1.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  }
}
