{
  "name": "tenancyjs-adapter-typeorm",
  "version": "0.2.0",
  "description": "Fail-closed TypeORM 1 tenant isolation for PostgreSQL and MySQL.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/package.json",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tenancyjs-adapter-shared": "workspace:*",
    "tenancyjs-core": "workspace:*"
  },
  "peerDependencies": {
    "typeorm": ">=1.0.0 <2"
  },
  "devDependencies": {
    "mysql2": "3.22.5",
    "pg": "8.16.3",
    "typeorm": "1.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karthick-Ramachandran/TenancyJS.git",
    "directory": "packages/adapter-typeorm"
  },
  "homepage": "https://github.com/Karthick-Ramachandran/TenancyJS#readme",
  "bugs": "https://github.com/Karthick-Ramachandran/TenancyJS/issues",
  "author": "Karthick Ramachandran",
  "keywords": [
    "multi-tenancy",
    "multitenancy",
    "tenancy",
    "saas",
    "tenant-isolation",
    "postgres",
    "mysql",
    "typescript",
    "typeorm",
    "rls"
  ],
  "module": "./dist/index.js"
}
