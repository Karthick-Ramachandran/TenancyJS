generator client {
  provider = "prisma-client"
  output   = "../../../.artifacts/prisma/adapter-prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id   String @id
  name String
}

model Post {
  id        String    @id @default(uuid())
  tenantId  String
  title     String
  published Boolean   @default(false)
  comments  Comment[]

  @@index([tenantId])
}

model Comment {
  id       String @id @default(uuid())
  tenantId String
  postId   String
  body     String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([postId])
}

// Dedicated to the RLS-backed row-level integration test (ADR-0037) so its
// forced-RLS state and restricted role never contend with the facade tests that
// share the Post table. The test creates and drops this table itself.
model RlsPost {
  id        String  @id @default(uuid())
  tenantId  String
  title     String
  published Boolean @default(false)

  @@index([tenantId])
}
