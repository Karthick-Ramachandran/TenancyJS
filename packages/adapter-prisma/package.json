{
  "name": "tenancyjs-adapter-prisma",
  "version": "0.1.1",
  "description": "Fail-closed row-level tenant isolation for Prisma Client.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/package.json",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "MIGRATION.md",
    "BENCHMARK.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tenancyjs-adapter-shared": "workspace:*",
    "tenancyjs-core": "workspace:*"
  },
  "peerDependencies": {
    "@prisma/client": ">=7.8.0 <7.9.0"
  },
  "scripts": {
    "build": "tsc -b",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:generate:mysql": "prisma generate --schema prisma/schema.mysql.prisma",
    "prisma:test:push": "prisma db push --config prisma.config.ts",
    "prisma:test:push:mysql": "prisma db push --config prisma.mysql.config.ts",
    "typecheck": "tsc -b --pretty false"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karthick-Ramachandran/TenancyJS.git",
    "directory": "packages/adapter-prisma"
  },
  "homepage": "https://github.com/Karthick-Ramachandran/TenancyJS#readme",
  "bugs": "https://github.com/Karthick-Ramachandran/TenancyJS/issues",
  "author": "Karthick Ramachandran",
  "keywords": [
    "multi-tenancy",
    "multitenancy",
    "tenancy",
    "saas",
    "tenant-isolation",
    "postgres",
    "typescript",
    "prisma",
    "mysql"
  ],
  "module": "./dist/index.js"
}
