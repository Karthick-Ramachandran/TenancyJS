{
  "name": "tenancyjs-cli",
  "version": "0.1.1",
  "description": "Operational CLI for TenancyJS: scaffold, inspect, and run tenant registry, provisioning, and migration commands against your own tenancy config.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "tenancy": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karthick-Ramachandran/TenancyJS.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Karthick-Ramachandran/TenancyJS#readme",
  "bugs": "https://github.com/Karthick-Ramachandran/TenancyJS/issues",
  "author": "Karthick Ramachandran",
  "keywords": [
    "multi-tenancy",
    "multitenancy",
    "tenancy",
    "saas",
    "tenant-isolation",
    "postgres",
    "typescript",
    "cli",
    "migrations",
    "provisioning",
    "tenant-management"
  ]
}
