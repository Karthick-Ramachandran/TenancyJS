{
  "name": "tenancyjs-integration-adonis",
  "version": "0.1.2",
  "description": "Fail-closed AdonisJS 7 request lifecycle integration for TenancyJS Lucid tenancy.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/package.json",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js",
      "require": "./dist/cjs/provider.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/cjs/testing.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tenancyjs-adapter-lucid": "workspace:*",
    "tenancyjs-core": "workspace:*",
    "tenancyjs-identifiers": "workspace:*"
  },
  "peerDependencies": {
    "@adonisjs/core": ">=7.3.0 <8",
    "@adonisjs/lucid": ">=22.4.0 <23"
  },
  "devDependencies": {
    "@adonisjs/core": "7.3.4",
    "@adonisjs/lucid": "22.4.2",
    "luxon": "3.7.2",
    "pg": "8.20.0",
    "youch": "4.1.1"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karthick-Ramachandran/TenancyJS.git",
    "directory": "packages/integration-adonis"
  },
  "homepage": "https://github.com/Karthick-Ramachandran/TenancyJS#readme",
  "bugs": "https://github.com/Karthick-Ramachandran/TenancyJS/issues",
  "author": "Karthick Ramachandran",
  "keywords": [
    "multi-tenancy",
    "multitenancy",
    "tenancy",
    "saas",
    "tenant-isolation",
    "postgres",
    "typescript",
    "adonisjs",
    "middleware"
  ],
  "module": "./dist/index.js"
}
