{
  "name": "@tenancyjs/adapter-knex",
  "version": "0.0.0",
  "description": "Fail-closed PostgreSQL row-level tenancy for Knex.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@tenancyjs/core": "workspace:*"
  },
  "peerDependencies": {
    "knex": ">=3.3.0 <3.4.0"
  },
  "devDependencies": {
    "knex": "3.3.0"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  }
}
