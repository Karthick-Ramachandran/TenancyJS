{
  "name": "tenancyjs-adapter-shared",
  "version": "0.1.0-beta.0",
  "description": "Shared isolation strategy primitives for TenancyJS adapters.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tenancyjs-core": "workspace:*"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karthick-Ramachandran/TenancyJS.git",
    "directory": "packages/adapter-shared"
  },
  "homepage": "https://github.com/Karthick-Ramachandran/TenancyJS#readme",
  "bugs": "https://github.com/Karthick-Ramachandran/TenancyJS/issues",
  "author": "Karthick Ramachandran",
  "keywords": [
    "multi-tenancy",
    "multitenancy",
    "tenancy",
    "saas",
    "tenant-isolation",
    "postgres",
    "typescript",
    "adapter",
    "isolation"
  ]
}
