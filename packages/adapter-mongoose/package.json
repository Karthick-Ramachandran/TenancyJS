{
  "name": "@tenancyjs/adapter-mongoose",
  "version": "0.0.0",
  "description": "Fail-closed Mongoose 9 tenant isolation for MongoDB.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@tenancyjs/adapter-shared": "workspace:*",
    "@tenancyjs/core": "workspace:*"
  },
  "peerDependencies": {
    "mongoose": ">=9.7.0 <10"
  },
  "devDependencies": {
    "mongoose": "9.7.3"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  }
}
