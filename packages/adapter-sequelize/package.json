{
  "name": "tenancyjs-adapter-sequelize",
  "version": "0.1.0-beta.1",
  "description": "Fail-closed Sequelize 6 tenant isolation for PostgreSQL and MySQL.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tenancyjs-adapter-shared": "workspace:*",
    "tenancyjs-core": "workspace:*"
  },
  "peerDependencies": {
    "sequelize": ">=6.37.0 <7"
  },
  "devDependencies": {
    "mysql2": "3.22.5",
    "sequelize": "6.37.8"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karthick-Ramachandran/TenancyJS.git",
    "directory": "packages/adapter-sequelize"
  },
  "homepage": "https://github.com/Karthick-Ramachandran/TenancyJS#readme",
  "bugs": "https://github.com/Karthick-Ramachandran/TenancyJS/issues",
  "author": "Karthick Ramachandran",
  "keywords": [
    "multi-tenancy",
    "multitenancy",
    "tenancy",
    "saas",
    "tenant-isolation",
    "postgres",
    "mysql",
    "typescript",
    "sequelize",
    "rls"
  ]
}
