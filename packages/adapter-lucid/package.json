{
  "name": "tenancyjs-adapter-lucid",
  "version": "0.2.0",
  "description": "Fail-closed PostgreSQL row-level and schema-per-tenant isolation for AdonisJS Lucid.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/package.json",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tenancyjs-adapter-shared": "workspace:*",
    "tenancyjs-core": "workspace:*"
  },
  "peerDependencies": {
    "@adonisjs/core": ">=7.3.0 <8",
    "@adonisjs/lucid": ">=22.4.0 <23",
    "luxon": ">=3.7.0 <4",
    "pg": ">=8.20.0 <9"
  },
  "devDependencies": {
    "@adonisjs/core": "7.3.5",
    "@adonisjs/lucid": "22.4.2",
    "luxon": "3.7.2",
    "pg": "8.20.0",
    "youch": "4.1.1"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karthick-Ramachandran/TenancyJS.git",
    "directory": "packages/adapter-lucid"
  },
  "homepage": "https://github.com/Karthick-Ramachandran/TenancyJS#readme",
  "bugs": "https://github.com/Karthick-Ramachandran/TenancyJS/issues",
  "author": "Karthick Ramachandran",
  "keywords": [
    "multi-tenancy",
    "multitenancy",
    "tenancy",
    "saas",
    "tenant-isolation",
    "postgres",
    "typescript",
    "lucid",
    "adonisjs",
    "rls"
  ],
  "module": "./dist/index.js"
}
