{
  "name": "tenancyjs-integration-nest",
  "version": "0.1.0-beta.6",
  "description": "Fail-closed NestJS 11 request lifecycle integration for TenancyJS.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/package.json",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tenancyjs-core": "workspace:*",
    "tenancyjs-identifiers": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": ">=11.1.0 <12",
    "@nestjs/core": ">=11.1.0 <12",
    "rxjs": ">=7.8.0 <8"
  },
  "devDependencies": {
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "rxjs": "7.8.2"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karthick-Ramachandran/TenancyJS.git",
    "directory": "packages/integration-nest"
  },
  "homepage": "https://github.com/Karthick-Ramachandran/TenancyJS#readme",
  "bugs": "https://github.com/Karthick-Ramachandran/TenancyJS/issues",
  "author": "Karthick Ramachandran",
  "keywords": [
    "multi-tenancy",
    "multitenancy",
    "tenancy",
    "saas",
    "tenant-isolation",
    "postgres",
    "typescript",
    "nestjs",
    "interceptor"
  ],
  "module": "./dist/index.js"
}
