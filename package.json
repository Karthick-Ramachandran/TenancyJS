{
  "name": "tenancyjs",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript-first, fail-closed multi-tenancy for the Node.js ecosystem.",
  "type": "module",
  "packageManager": "pnpm@10.12.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "format": "prettier --write . --ignore-path .prettierignore",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "test": "vitest",
    "test:run": "pnpm build && vitest run",
    "pack:check": "pnpm build && node scripts/pack-check.mjs",
    "memory:check": "persist doctor",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test:run && pnpm pack:check && pnpm memory:check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@eslint/js": "10.0.1",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.6.0",
    "persist-os": "0.6.1",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  }
}
